# Lesson 6 -- Azure AI Vision web app
# Copy this file to .env and paste your real values.
# Never commit your .env to source control.

# Your Azure AI Vision resource endpoint.
# Example: https://YOUR-RESOURCE-NAME.cognitiveservices.azure.com/
VISION_ENDPOINT=https://YOUR-RESOURCE-NAME.cognitiveservices.azure.com/

# Key 1 or Key 2 from your Azure AI Vision resource (Azure portal > Keys and Endpoint).
VISION_KEY=YOUR_VISION_KEY_HERE
