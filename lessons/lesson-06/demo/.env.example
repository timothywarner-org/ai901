# Lesson 06 -- Azure AI Vision (ComputerVision F0)
#
# After running Deploy-Lesson06-Infrastructure.ps1, get your values with:
#
#   az cognitiveservices account show \
#     -g rg-ai901-lesson06-demo -n ai901-lesson06-vision \
#     --query properties.endpoint -o tsv
#
#   az cognitiveservices account keys list \
#     -g rg-ai901-lesson06-demo -n ai901-lesson06-vision \
#     --query key1 -o tsv
#
# NOTE: the Vision resource is in East US (not East US 2) because the Caption
# visual feature is region-gated. The endpoint will show eastus in its hostname.
#
# NEVER commit .env to source control -- only .env.example belongs here.
# NEVER share your key. Rotate it immediately if it is exposed.

VISION_ENDPOINT=https://YOUR-RESOURCE-NAME.cognitiveservices.azure.com/
VISION_KEY=PASTE_YOUR_VISION_KEY1_HERE
