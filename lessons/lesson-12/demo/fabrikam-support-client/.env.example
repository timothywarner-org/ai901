# Lesson 12 fabrikam-support-client -- copy to .env and fill in.
# KEYLESS: no API key is needed.
# NEVER commit .env to source control -- only .env.example.
#
# No AGENT_ID needed here -- the client creates its own classic assistant.
#
# The endpoint is on the Foundry project Overview page (https://ai.azure.com).
# You can reuse the Lesson 11 or Lesson 12 project endpoint.

FOUNDRY_PROJECT_ENDPOINT=https://YOUR-FOUNDRY-NAME.services.ai.azure.com/api/projects/YOUR-PROJECT-NAME
FOUNDRY_MODEL_NAME=gpt-4o
