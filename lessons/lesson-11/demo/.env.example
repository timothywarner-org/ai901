# Lesson 11 -- Foundry Agents SDK bookend (KEYLESS AUTH)
# Copy this file to .env and fill in the two values below.
# NEVER commit .env to source control -- only .env.example.
#
# Auth pattern: keyless (DefaultAzureCredential). No API key is needed.
# The credential chain picks up your az login token at runtime.
# Pre-requisite: az login, and Cognitive Services OpenAI User role on the
# Foundry resource (the deploy script assigns this automatically).
#
# FOUNDRY_PROJECT_ENDPOINT -- the URL on the Foundry project Overview page
#   at https://ai.azure.com. Format:
#   https://<foundry-name>.services.ai.azure.com/api/projects/<project-name>
#   Example:
#   https://ai901-lesson11-foundry.services.ai.azure.com/api/projects/ai901-lesson11-project
#
# AGENT_ID -- copy from the Foundry portal -> Agents tab after you build
#   the agent in Beat 1. In the new Foundry the agent ID is its name
#   (e.g. contoso-docs-assistant), not an asst_... identifier.

FOUNDRY_PROJECT_ENDPOINT=https://YOUR-FOUNDRY-NAME.services.ai.azure.com/api/projects/YOUR-PROJECT-NAME
AGENT_ID=REPLACE_WITH_YOUR_AGENT_ID
