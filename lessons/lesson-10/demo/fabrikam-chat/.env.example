# Lesson 10 fabrikam-chat -- copy to .env and fill in. KEYLESS: no key needed.
#
# SETUP:
#   1. Run Deploy-Lesson10-Infrastructure.ps1 to provision the Foundry project.
#   2. Copy this file to .env in this folder.
#   3. Paste the FOUNDRY_PROJECT_ENDPOINT from the deploy script output.
#   4. NEVER commit .env to source control.
#
# FOUNDRY_PROJECT_ENDPOINT is on the Foundry project Overview page:
#   https://ai.azure.com -> your project -> Overview -> Project endpoint
# The format is:
#   https://YOUR-RESOURCE-NAME.services.ai.azure.com/api/projects/YOUR-PROJECT-NAME
#
# FOUNDRY_MODEL_NAME must match the DEPLOYMENT name in your project (not the
# underlying model family name).

FOUNDRY_PROJECT_ENDPOINT=https://YOUR-RESOURCE-NAME.services.ai.azure.com/api/projects/YOUR-PROJECT-NAME
FOUNDRY_MODEL_NAME=gpt-4o
