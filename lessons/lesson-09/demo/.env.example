# Lesson 9 -- Prompt Engineering via Microsoft Foundry (gpt-4o, Structured Outputs)
#
# SETUP:
#   1. Run Deploy-Lesson09-Infrastructure.ps1 to provision the Foundry resource.
#   2. Copy this file to .env in the same folder.
#   3. Paste the values printed by the deploy script.
#   4. NEVER commit .env to source control.
#
# Get the endpoint:
#   az cognitiveservices account show \
#     -g rg-ai901-lesson09-demo -n YOUR-FOUNDRY-NAME \
#     --query properties.endpoint -o tsv
#
# Get the key:
#   az cognitiveservices account keys list \
#     -g rg-ai901-lesson09-demo -n YOUR-FOUNDRY-NAME \
#     --query key1 -o tsv
#
# AZURE_OPENAI_CHAT_DEPLOYMENT is the DEPLOYMENT name (not the model name).
# The deploy script names the deployment "gpt-4o" -- deployment name == model name for
# this lesson, because gpt-4o 2024-11-20 is GA and deployable under its real name.
#
# AZURE_OPENAI_API_VERSION 2024-10-21 is the GA api-version that supports Structured
# Outputs. Older versions silently fall back to JSON mode with no schema guarantee.
# The exam may ask about the minimum api-version for Structured Outputs:
# the answer is 2024-08-01-preview (preview) or 2024-10-21 (GA).

AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.cognitiveservices.azure.com/
AZURE_OPENAI_KEY=PASTE_KEY_HERE
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21
