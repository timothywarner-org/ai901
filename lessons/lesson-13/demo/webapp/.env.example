# Lesson 13 -- Azure AI Language web app (keyless)
# Copy this file to .env and paste your real values.
# Never commit your .env to source control.
#
# NOTE: No key is needed. This app uses DefaultAzureCredential (keyless auth).
# The signed-in identity (az login) must have the "Cognitive Services User"
# role on the Language resource. Role propagation can take up to 5 minutes.

# Your Azure AI Language resource endpoint.
# IMPORTANT: this must be the custom-subdomain form for Entra auth to work.
# Example: https://YOUR-RESOURCE-NAME.cognitiveservices.azure.com/
LANGUAGE_ENDPOINT=https://YOUR-RESOURCE-NAME.cognitiveservices.azure.com/
