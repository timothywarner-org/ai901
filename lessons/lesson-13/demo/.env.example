# ---------------------------------------------------------------------------
# Lesson 13 -- Azure AI Language (AIServices, keyless auth)
#
# KEYLESS: there is no key line in this file. The SDK authenticates with
# DefaultAzureCredential, which picks up your `az login` session on a
# developer laptop and a managed identity in Azure. The signed-in user
# (or managed identity) must hold the "Cognitive Services User" role on
# the Language resource -- Deploy-Lesson13-Infrastructure.ps1 auto-assigns it.
#
# How to get the endpoint:
#   az cognitiveservices account show \
#     -g rg-ai901-lesson13-demo \
#     -n <your-language-resource-name> \
#     --query properties.endpoint -o tsv
#
# The endpoint MUST be a custom-subdomain URL of the form:
#   https://<your-resource-name>.cognitiveservices.azure.com/
# A regional endpoint (e.g. https://eastus2.api.cognitive.microsoft.com/)
# will REJECT Entra token auth -- this is the most common keyless gotcha.
# ---------------------------------------------------------------------------
LANGUAGE_ENDPOINT=https://YOUR-RESOURCE-NAME.cognitiveservices.azure.com/

# NEVER commit the real .env file to source control.
