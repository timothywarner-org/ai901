# Lesson 05 -- Azure AI Language (TextAnalytics F0)
#
# After running Deploy-Lesson05-Infrastructure.ps1, get your values with:
#
#   az cognitiveservices account show \
#     -g rg-ai901-lesson05-demo -n ai901-lesson05-language \
#     --query properties.endpoint -o tsv
#
#   az cognitiveservices account keys list \
#     -g rg-ai901-lesson05-demo -n ai901-lesson05-language \
#     --query key1 -o tsv
#
# NEVER commit .env to source control -- only .env.example belongs here.
# NEVER share your key. Rotate it immediately if it is exposed.

LANGUAGE_ENDPOINT=https://YOUR-RESOURCE-NAME.cognitiveservices.azure.com/
LANGUAGE_KEY=PASTE_YOUR_LANGUAGE_KEY1_HERE
