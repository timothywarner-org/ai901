# Lesson 07 -- Azure AI Content Understanding (Foundry AIServices, GA 2025-11-01)
#
# After running Deploy-Lesson07-Infrastructure.ps1, get your values with:
#
#   az cognitiveservices account show \
#     -g rg-ai901-lesson07-demo -n ai901-lesson07-foundry \
#     --query properties.endpoint -o tsv
#
#   az cognitiveservices account keys list \
#     -g rg-ai901-lesson07-demo -n ai901-lesson07-foundry \
#     --query key1 -o tsv
#
# CONTENT_UNDERSTANDING_ENDPOINT is the Foundry resource endpoint --
# the cognitiveservices.azure.com form (not services.ai.azure.com).
# Content Understanding GA uses the cognitiveservices form for the
# /contentunderstanding/... path.
#
# NEVER commit .env to source control -- only .env.example belongs here.
# NEVER share your key. Rotate it immediately if it is exposed.

CONTENT_UNDERSTANDING_ENDPOINT=https://YOUR-RESOURCE-NAME.cognitiveservices.azure.com/
CONTENT_UNDERSTANDING_KEY=PASTE_YOUR_FOUNDRY_KEY1_HERE
CONTENT_UNDERSTANDING_API_VERSION=2025-11-01
