# Lesson 7 -- Azure AI Content Understanding web app
# Copy this file to .env and paste your real values.
# Never commit your .env to source control.

# Your Microsoft Foundry (Azure AI services) resource endpoint.
# Example: https://YOUR-RESOURCE-NAME.cognitiveservices.azure.com/
CONTENT_UNDERSTANDING_ENDPOINT=https://YOUR-RESOURCE-NAME.cognitiveservices.azure.com/

# Key 1 or Key 2 from your Azure AI services resource (Azure portal > Keys and Endpoint).
CONTENT_UNDERSTANDING_KEY=YOUR_CONTENT_UNDERSTANDING_KEY_HERE

# GA api-version for Content Understanding -- do not change unless Microsoft
# releases a new stable version.
CONTENT_UNDERSTANDING_API_VERSION=2025-11-01
